<!DOCTYPE html>
<!-- deploy-version: tools-gallery-v7 -->
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Downloads — Leviathan</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="styles.css?v=7" />
</head>
<body class="page downloads-page">
  <div class="page-glow" aria-hidden="true"></div>

  <header class="bar bar-tools">
    <a class="back" href="index.html">← Leviathan</a>
  </header>

  <main class="content tools-content">
    <header class="tools-hero">
      <h1>Downloads</h1>
      <p class="lede">Click to download — counts stay once per PC.</p>
    </header>

    <section class="tool-grid" aria-label="Tools">
      <a
        class="tool-card tracked tool-card--flag"
        href="downloads/tools/fflag.ahk"
        data-counter="fflag-ahk"
        download="fflag.ahk"
        style="--delay: 0.05s"
      >
        <div class="tool-visual" aria-hidden="true">
          <img src="assets/tool-fflag.svg" alt="" width="220" height="160" />
          <span class="tool-orb"></span>
        </div>
        <div class="tool-info">
          <div class="tool-top">
            <span class="tool-badge">AutoHotkey</span>
            <span class="tool-file">fflag.ahk</span>
          </div>
          <h2>FFlag</h2>
          <p>Manage and change your FFlag injector on a roblox client.</p>
          <div class="tool-foot">
            <span class="dl-meta"><span class="dl-count" data-count-for="fflag-ahk">…</span> downloads</span>
            <span class="tool-cta">Download <span aria-hidden="true">↓</span></span>
          </div>
        </div>
      </a>

      <a
        class="tool-card tracked tool-card--hub"
        href="downloads/tools/Hub.zip"
        data-counter="hub-zip"
        download="Hub.zip"
        style="--delay: 0.18s"
      >
        <div class="tool-visual" aria-hidden="true">
          <img src="assets/tool-hub.svg" alt="" width="220" height="160" />
          <span class="tool-orb"></span>
        </div>
        <div class="tool-info">
          <div class="tool-top">
            <span class="tool-badge">Package</span>
            <span class="tool-file">Hub.zip</span>
          </div>
          <h2>Hub</h2>
          <p>Macro hub pack ready to unzip and run — settings included.</p>
          <div class="tool-foot">
            <span class="dl-meta"><span class="dl-count" data-count-for="hub-zip">…</span> downloads</span>
            <span class="tool-cta">Download <span aria-hidden="true">↓</span></span>
          </div>
        </div>
      </a>
    </section>
  </main>

  <script src="download-counts.js?v=7"></script>
</body>
</html>
